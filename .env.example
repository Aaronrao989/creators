# Copy to .env and point at any PostgreSQL instance
# (local, Docker, Supabase, Neon, Prisma Postgres, RDS, …)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/creators_home?schema=public"

# Secret used to sign auth session cookies. Set a long random value in production
# (e.g. `openssl rand -base64 32`). A dev fallback is used if unset.
AUTH_SECRET="change-me-to-a-long-random-string"
